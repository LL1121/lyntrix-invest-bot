# --- Desarrollo local (Python fuera de Docker) ---
DB_HOST=127.0.0.1
DB_PORT=5435
DB_USER=lyntrix_admin
DB_PASSWORD=lyntrix_pass
DB_NAME=lyntrix_invest

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- Docker Compose (mapeo en el HOST; los contenedores ignoran DB_HOST/REDIS_HOST del .env) ---
# Postgres y Redis quedan enlazados a loopback por defecto (más seguro en un VPS).
# Para escuchar en todas las interfaces: DB_BIND=0.0.0.0 y REDIS_BIND=0.0.0.0
DB_BIND=127.0.0.1
REDIS_BIND=127.0.0.1
DASHBOARD_BIND=0.0.0.0
DASHBOARD_PORT=8501

# Docker: copiar a .env y ejecutar `docker compose up -d --build`.
# GROQ_API_KEY: orquestador (rationale vía LLM) y War Room (Oracle / Executive Briefing).
# FMP_API_KEY: calendar_agent (macro); resto según agentes que actives.
#
# Groq: varios contenedores comparten el mismo GROQ_MODEL y el cupo TPD/TPM del plan.
# Usá un modelo chico (p. ej. llama-3.1-8b-instant) o subí tier en console.groq.com.
# NewsAPI 429: normal en plan free; GeoOracle cae a headlines mock / fallback.
# Redis "vm.overcommit_memory": aviso del host; en Linux: sysctl vm.overcommit_memory=1

PAPER_START_BALANCE=10000
PAPER_ALLOCATION_FRACTION=0.10
PAPER_FEE_RATE=0.001
PAPER_SLIPPAGE_RATE=0.0005
EXECUTOR_DEFAULT_SYMBOL=HG=F

VALUE_HUNTER_ENERGY_ETF=NLR
LLM_PROVIDER=groq
GROQ_MODEL=llama-3.1-8b-instant

GROQ_API_KEY=
NEWS_API_KEY=
ALPHAVANTAGE_API_KEY=
FMP_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
